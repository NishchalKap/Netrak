## Expo public environment variables
## Any variable prefixed with EXPO_PUBLIC_ will be bundled into the client app.
## Do NOT put secrets here.

# Backend gateway base URL (default used by src/services/config.ts)
EXPO_PUBLIC_API_URL=http://localhost:3000/api

# Request behavior
EXPO_PUBLIC_API_TIMEOUT=10000
EXPO_PUBLIC_API_RETRY_ATTEMPTS=2
