# Runtime
NODE_ENV=development
PORT=3000
TRUST_PROXY=false

# Required in production. Use at least 32 random characters.
JWT_SECRET=replace-with-a-long-random-secret-before-production
JWT_ISSUER=netrak-gateway
JWT_AUDIENCE=netrak-clients
# Existing signed tokens may be renewed for 15 minutes after access expiry.
JWT_REFRESH_GRACE_SECONDS=900

# Supabase PostgreSQL / Prisma
# DATABASE_URL should use Supabase's transaction-pooler connection string for runtime traffic.
# DIRECT_URL should use the direct database connection string for Prisma CLI migrations.
# Both URLs must include sslmode=require when connecting to Supabase.
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&sslmode=require
DIRECT_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?sslmode=require

# Supabase Storage (optional until evidence file uploads are enabled)
SUPABASE_URL=https://[PROJECT-REF].supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=evidence

# Comma-separated browser origins. Wildcards are rejected in production.
CORS_ORIGINS=http://localhost:8081,http://localhost:4173
MAX_LIST_RESULTS=500

# API documentation is enabled by default outside production.
API_DOCS_ENABLED=true
PUBLIC_API_URL=http://localhost:3000/api

# Keep false in production. Privileged users should be provisioned administratively.
ALLOW_PRIVILEGED_REGISTRATION=false
# One-time plaintext legacy migration is intentionally unavailable in production.
ALLOW_LEGACY_PASSWORD_MIGRATION=false

# Development/demo reference guidance only. Keep false for authoritative production feeds.
LOAD_REFERENCE_ADVISORIES=false
