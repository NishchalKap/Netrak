# Required environment variables for the Netrak Gateway API

# Server configuration
PORT=3000
NODE_ENV=development

# Authentication & Security
JWT_SECRET=your-secure-jwt-secret-here-min-32-chars
REFRESH_TOKEN_SECRET=your-secure-refresh-token-secret-here-min-32-chars
JWT_ISSUER=netrak-gateway
JWT_AUDIENCE=netrak-clients
JWT_REFRESH_GRACE_SECONDS=900
ALLOW_PRIVILEGED_REGISTRATION=false
ALLOW_LEGACY_PASSWORD_MIGRATION=false

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/netrak
DIRECT_URL=postgresql://user:password@localhost:5432/netrak

# Supabase Storage (optional)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=netrak-evidence

# CORS
CORS_ORIGINS=http://localhost:4173,http://localhost:8081
TRUST_PROXY=false

# API Documentation
API_DOCS_ENABLED=true
PUBLIC_API_URL=

# AI Configuration
AI_SPEECH_PROVIDER=databricks
DATABRICKS_SPEECH_URL=
DATABRICKS_API_KEY=
AI_LLM_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Other
MAX_LIST_RESULTS=500
LOAD_REFERENCE_ADVISORIES=true

# Optional seed/demo accounts
SEED_ALLOW_PRODUCTION=false
SEED_ADMIN_PASSWORD=
SEED_OFFICER_PASSWORD=
SEED_CITIZEN_PASSWORD=
