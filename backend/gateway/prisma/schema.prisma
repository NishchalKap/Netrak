// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["public", "auth"]
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      String   @default("CITIZEN")
  name      String?
  phone     String?
  district  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cases         Case[]
  notifications Notification[]
  @@schema("public")
}

model Case {
  id          String   @id @default(uuid())
  title       String
  description String
  status      String   @default("OPEN")
  category    String?
  riskLevel   String?
  location    String?
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  evidence CaseEvidence[]
  timeline CaseTimelineEvent[]

  @@index([userId, createdAt(sort: Desc)])
  @@index([status, updatedAt(sort: Desc)])
  @@schema("public")
}

model CaseEvidence {
  id        String   @id @default(uuid())
  type      String
  label     String
  reference String
  notes     String?
  caseId    String
  case      Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([caseId, createdAt(sort: Desc)])
  @@schema("public")
}

model CaseTimelineEvent {
  id        String   @id @default(uuid())
  title     String
  detail    String
  caseId    String
  case      Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([caseId, createdAt(sort: Desc)])
  @@schema("public")
}

model Notification {
  id        String   @id @default(uuid())
  message   String
  read      Boolean  @default(false)
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, read])
  @@schema("public")
}

model Threat {
  id         String   @id @default(uuid())
  title      String
  category   String
  level      String
  region     String
  summary    String
  indicators Json
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())

  @@index([category])
  @@index([level])
  @@index([region])
  @@index([updatedAt(sort: Desc)])
  @@schema("public")
}

model AIResult {
  id          String   @id @default(uuid())
  provider    String
  serviceType String
  inputRef    String?
  output      Json
  createdAt   DateTime @default(now())

  @@index([provider])
  @@index([serviceType])
  @@index([createdAt(sort: Desc)])
  @@schema("public")
}

model Embedding {
  id          String   @id @default(uuid())
  entityType  String
  entityId    String
  vector      Json
  createdAt   DateTime @default(now())

  @@index([entityType, entityId])
  @@schema("public")
}

model Transcription {
  id          String   @id @default(uuid())
  referenceId String
  language    String?
  text        String
  confidence  Float?
  createdAt   DateTime @default(now())

  @@index([referenceId])
  @@schema("public")
}

model Entity {
  id          String   @id @default(uuid())
  type        String
  value       String
  context     String?
  sourceId    String?
  createdAt   DateTime @default(now())

  @@index([type])
  @@index([value])
  @@schema("public")
}

model ThreatScore {
  id          String   @id @default(uuid())
  referenceId String
  score       Float
  factors     Json
  createdAt   DateTime @default(now())

  @@index([referenceId])
  @@schema("public")
}

model AIInferenceHistory {
  id          String   @id @default(uuid())
  provider    String
  serviceType String
  status      String
  durationMs  Int?
  request     Json?
  response    Json?
  error       String?
  createdAt   DateTime @default(now())

  @@index([provider])
  @@index([status])
  @@index([createdAt(sort: Desc)])
  @@schema("public")
}
